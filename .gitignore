# ── Data, submissions (excluded from tracking / pushes) ──
Data/
submissions/

# reports/: track the HTML report + experiment logs (deliverables); ignore everything else
reports/*
!reports/best_experiments.html
!reports/experiment_logs/

# Other generated artifacts (large model / pipeline outputs)
outputs/
generator_outputs/


# ── Markdown docs (excluded from tracking / pushes) — except README & the experiment log ──
*.md
!README.md
!EXPERIMENTS.md

# ── Python ──
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
.ipynb_checkpoints/

# ── OS / editor ──
.DS_Store
.idea/
.vscode/
*.swp
